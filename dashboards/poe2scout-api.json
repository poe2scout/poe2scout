        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 3,
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 99 },
              { "color": "green", "value": 99.9 }
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "100 * sum(rate(poe2scout_api_http_requests_total{service_name=\"poe2scout.api\",deployment_environment=~\"${environment:regex}\",http_route=~\"${route:regex}\",request_outcome=\"success\"}[$__rate_interval])) / clamp_min(sum(rate(poe2scout_api_http_requests_total{service_name=\"poe2scout.api\",deployment_environment=~\"${environment:regex}\",http_route=~\"${route:regex}\",request_outcome=~\"success|server_error\"}[$__rate_interval])), 0.000000001)",
