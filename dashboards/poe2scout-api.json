  "description": "Endpoint-specific RED metrics and structured request logs for the POE2 Scout API.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "wideLayout": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(rate(poe2scout_api_http_requests_total{service_name=\"poe2scout.api\",deployment_environment=~\"${environment:regex}\",http_route=~\"${route:regex}\"}[$__rate_interval]))",
          "instant": false,
          "legendFormat": "requests/sec",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Request Rate",
      "type": "stat"
