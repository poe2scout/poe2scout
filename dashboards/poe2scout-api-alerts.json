{
  "apiVersion": 1,
  "groups": [
    {
      "orgId": 1,
      "name": "POE2 Scout API",
      "folder": "POE2 Scout",
      "interval": "1m",
      "rules": [
        {
          "uid": "poe2-api-error-log",
          "title": "API request failure volume high",
          "condition": "B",
          "data": [
            {
              "refId": "A",
              "queryType": "instant",
              "relativeTimeRange": { "from": 600, "to": 0 },
              "datasourceUid": "REPLACE_WITH_GRAFANA_CLOUD_LOKI_UID",
              "model": {
                "datasource": {
                  "type": "loki",
                  "uid": "REPLACE_WITH_GRAFANA_CLOUD_LOKI_UID"
                },
                "editorMode": "code",
                "expr": "sum(count_over_time({service_name=\"poe2scout.api\", deployment_environment=\"production\"} |= \"API request failed\" [5m]))",
                "instant": true,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "queryType": "instant",
                "range": false,
                "refId": "A"
              }
            },
            {
              "refId": "B",
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 },
              "datasourceUid": "__expr__",
              "model": {
                "conditions": [
                  {
                    "evaluator": { "params": [50], "type": "gt" },
                    "operator": { "type": "and" },
                    "query": { "params": ["A"] },
                    "reducer": { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "datasource": { "type": "__expr__", "uid": "__expr__" },
                "hide": false,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "B",
                "type": "classic_conditions"
              }
            }
          ],
          "dashboardUid": "poe2scout-api",
          "panelId": 12,
          "noDataState": "OK",
          "execErrState": "Error",
          "for": "0s",
          "keepFiringFor": "2m",
          "annotations": {
            "summary": "The POE2 Scout API logged more than 50 request failures in five minutes",
            "description": "More than 50 structured API request failures were logged in production during the last five minutes. Open the linked API Errors panel for exceptions and trace IDs."
          },
          "labels": {
            "service": "poe2scout-api",
            "environment": "production",
            "severity": "warning",
            "signal": "logs"
          },
          "isPaused": false
        },
        {
          "uid": "poe2-api-error-burst",
          "title": "API 5xx error detected",
          "condition": "B",
          "data": [
            {
              "refId": "A",
              "queryType": "",
              "relativeTimeRange": { "from": 600, "to": 0 },
              "datasourceUid": "REPLACE_WITH_GRAFANA_CLOUD_PROMETHEUS_UID",
              "model": {
                "datasource": {
                  "type": "prometheus",
                  "uid": "REPLACE_WITH_GRAFANA_CLOUD_PROMETHEUS_UID"
                },
                "editorMode": "code",
                "expr": "sum(increase(poe2scout_api_http_requests_total{service_name=\"poe2scout.api\",deployment_environment=\"production\",request_outcome=\"server_error\"}[5m]))",
                "instant": true,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "range": false,
                "refId": "A"
              }
            },
            {
              "refId": "B",
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 },
              "datasourceUid": "__expr__",
              "model": {
                "conditions": [
                  {
                    "evaluator": { "params": [0], "type": "gt" },
                    "operator": { "type": "and" },
                    "query": { "params": ["A"] },
                    "reducer": { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "datasource": { "type": "__expr__", "uid": "__expr__" },
                "hide": false,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "B",
                "type": "classic_conditions"
              }
            }
          ],
          "dashboardUid": "poe2scout-api",
          "panelId": 3,
          "noDataState": "OK",
          "execErrState": "Error",
          "for": "0s",
          "keepFiringFor": "5m",
          "annotations": {
            "summary": "The POE2 Scout API returned a 5xx response",
            "description": "At least one server error occurred in production during the last five minutes."
          },
          "labels": {
            "service": "poe2scout-api",
            "environment": "production",
            "severity": "critical",
            "signal": "metrics"
          },
          "isPaused": false
        },
        {
          "uid": "poe2-api-high-p95",
          "title": "API p95 latency high",
          "condition": "B",
          "data": [
            {
              "refId": "A",
              "queryType": "",
              "relativeTimeRange": { "from": 900, "to": 0 },
              "datasourceUid": "REPLACE_WITH_GRAFANA_CLOUD_PROMETHEUS_UID",
              "model": {
                "datasource": {
                  "type": "prometheus",
                  "uid": "REPLACE_WITH_GRAFANA_CLOUD_PROMETHEUS_UID"
                },
                "editorMode": "code",
                "expr": "histogram_quantile(0.95, sum by (le) (rate(poe2scout_api_http_request_duration_seconds_bucket{service_name=\"poe2scout.api\",deployment_environment=\"production\"}[5m])))",
                "instant": true,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "range": false,
                "refId": "A"
              }
            },
            {
              "refId": "B",
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 },
              "datasourceUid": "__expr__",
              "model": {
                "conditions": [
                  {
                    "evaluator": { "params": [1.5], "type": "gt" },
                    "operator": { "type": "and" },
                    "query": { "params": ["A"] },
                    "reducer": { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "datasource": { "type": "__expr__", "uid": "__expr__" },
                "hide": false,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "B",
                "type": "classic_conditions"
              }
            }
          ],
          "dashboardUid": "poe2scout-api",
          "panelId": 5,
          "noDataState": "OK",
          "execErrState": "Error",
          "for": "10m",
          "keepFiringFor": "5m",
          "annotations": {
            "summary": "The POE2 Scout API p95 latency is above 1.5 seconds",
            "description": "Production p95 request latency remained above 1.5 seconds for ten minutes."
          },
          "labels": {
            "service": "poe2scout-api",
            "environment": "production",
            "severity": "warning",
            "signal": "metrics"
          },
          "isPaused": false
        },
        {
          "uid": "poe2-api-high-4xx",
          "title": "API 4xx ratio high",
          "condition": "B",
          "data": [
            {
              "refId": "A",
              "queryType": "",
              "relativeTimeRange": { "from": 1200, "to": 0 },
              "datasourceUid": "REPLACE_WITH_GRAFANA_CLOUD_PROMETHEUS_UID",
              "model": {
                "datasource": {
                  "type": "prometheus",
                  "uid": "REPLACE_WITH_GRAFANA_CLOUD_PROMETHEUS_UID"
                },
                "editorMode": "code",
                "expr": "(100 * sum(rate(poe2scout_api_http_requests_total{service_name=\"poe2scout.api\",deployment_environment=\"production\",request_outcome=\"client_error\"}[10m])) / clamp_min(sum(rate(poe2scout_api_http_requests_total{service_name=\"poe2scout.api\",deployment_environment=\"production\"}[10m])), 0.000000001)) and on() (sum(increase(poe2scout_api_http_requests_total{service_name=\"poe2scout.api\",deployment_environment=\"production\"}[10m])) >= 20)",
                "instant": true,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "range": false,
                "refId": "A"
              }
            },
            {
              "refId": "B",
              "queryType": "",
              "relativeTimeRange": { "from": 0, "to": 0 },
              "datasourceUid": "__expr__",
              "model": {
                "conditions": [
                  {
                    "evaluator": { "params": [25], "type": "gt" },
                    "operator": { "type": "and" },
                    "query": { "params": ["A"] },
                    "reducer": { "params": [], "type": "last" },
                    "type": "query"
                  }
                ],
                "datasource": { "type": "__expr__", "uid": "__expr__" },
                "hide": false,
                "intervalMs": 1000,
                "maxDataPoints": 43200,
                "refId": "B",
                "type": "classic_conditions"
              }
            }
          ],
          "dashboardUid": "poe2scout-api",
          "panelId": 7,
          "noDataState": "OK",
          "execErrState": "Error",
          "for": "10m",
          "keepFiringFor": "5m",
          "annotations": {
            "summary": "More than 25% of POE2 Scout API requests are 4xx responses",
            "description": "The production client-error ratio remained above 25% for ten minutes. The rule requires at least 20 requests in its ten-minute window to avoid low-traffic noise."
          },
          "labels": {
            "service": "poe2scout-api",
            "environment": "production",
            "severity": "warning",
            "signal": "metrics"
          },
          "isPaused": false
        }
      ]
    }
  ]
}
