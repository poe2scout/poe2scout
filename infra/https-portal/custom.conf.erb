<% web_domain = ENV["WEB_DOMAIN"] || "poe2scout.com" %>

server {
    listen       80;
    <% if ENV['LISTEN_IPV6'] && ENV['LISTEN_IPV6'].downcase == 'true' %>
    listen       [::]:80;
    <% end %>
    server_name  <%= domain.name %>;

    location / {
      <% if domain.name == web_domain %>
      return    301 https://$server_name$request_uri;
      <% else %>
      return    301 https://<%= web_domain %>$request_uri;
      <% end %>
    }

    <%= acme_challenge_location %>

    <% if ENV['CUSTOM_NGINX_SERVER_PLAIN_CONFIG_BLOCK'] %>
      <%= ENV['CUSTOM_NGINX_SERVER_PLAIN_CONFIG_BLOCK'] %>
    <% end %>

}
